# Custom sandbox template for vibe-harness
# Extends the official Copilot CLI sandbox with development tools
# and wraps copilot to always run in ACP mode.
#
# Build:  docker build -t vibe-harness/copilot:latest -f docker/Dockerfile.copilot docker/
# Usage:  docker sandbox run --name my-sandbox -t vibe-harness/copilot:latest copilot .

FROM docker/sandbox-templates:copilot

# --- System packages (requires root) ---
USER root

# Node.js 25 via NodeSource
RUN curl -fsSL https://deb.nodesource.com/setup_25.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g pnpm typescript tsx \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# HashiCorp Terraform
RUN curl -fsSL https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /usr/share/keyrings/hashicorp.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/hashicorp.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" \
       > /etc/apt/sources.list.d/hashicorp.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends terraform \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# --- User-level tools (run as agent) ---
USER agent

# uv (includes uvx) — also used to install Python
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# Python 3.14 via uv (avoids PPA compatibility issues)
RUN $HOME/.local/bin/uv python install 3.14

# Ensure uv/uvx are on PATH for interactive shells
RUN echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.bashrc

# Smoke-test all tools
RUN export PATH="$HOME/.local/bin:$PATH" \
    && node --version \
    && npm --version \
    && pnpm --version \
    && tsc --version \
    && tsx --version \
    && python3.14 --version || $HOME/.local/bin/uv python install 3.14 \
    && uv --version \
    && uvx --version \
    && terraform --version

# Pre-configure MCP server for vibe-harness integration.
# Uses a stdio bridge script that proxies tool calls back to the host via curl
# (Node.js fetch doesn't respect HTTP_PROXY inside Docker sandboxes).
COPY --chown=agent:agent mcp-bridge/vibe-mcp-bridge.js /home/agent/.local/bin/vibe-mcp-bridge.js
RUN chmod +x /home/agent/.local/bin/vibe-mcp-bridge.js \
    && mkdir -p /home/agent/.copilot \
    && printf '{"mcpServers":{"vibe-harness":{"type":"local","command":"node","args":["/home/agent/.local/bin/vibe-mcp-bridge.js"],"env":{},"tools":["*"]}}}\n' \
       > /home/agent/.copilot/mcp-config.json
