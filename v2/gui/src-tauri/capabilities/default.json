{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-open",
    "notification:default",
    "autostart:default",
    "mcp-bridge:default"
  ]
}
